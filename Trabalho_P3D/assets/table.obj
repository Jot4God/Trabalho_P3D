mtllib table.mtl

o Table

# Vértices do topo da mesa
v -3.0  0.0 -1.5
v  3.0  0.0 -1.5
v  3.0  0.0  1.5
v -3.0  0.0  1.5

# Vértices da parte de baixo da mesa
v -3.0 -0.2 -1.5
v  3.0 -0.2 -1.5
v  3.0 -0.2  1.5
v -3.0 -0.2  1.5

# Coordenadas de textura
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normais
vn 0.0  1.0  0.0
vn 0.0 -1.0  0.0
vn 0.0  0.0  1.0
vn 0.0  0.0 -1.0
vn 1.0  0.0  0.0
vn -1.0 0.0  0.0

usemtl Table_Green

# --------------------------------------------------
# TOPO DA MESA
# Normal: +Y
# --------------------------------------------------
f 1/1/1 4/4/1 3/3/1
f 3/3/1 2/2/1 1/1/1

# --------------------------------------------------
# FUNDO DA MESA
# Normal: -Y
# --------------------------------------------------
f 5/1/2 6/2/2 7/3/2
f 7/3/2 8/4/2 5/1/2

# --------------------------------------------------
# LADO DA FRENTE
# Normal: +Z
# --------------------------------------------------
f 4/1/3 8/4/3 7/3/3
f 7/3/3 3/2/3 4/1/3

# --------------------------------------------------
# LADO DE TRÁS
# Normal: -Z
# --------------------------------------------------
f 1/1/4 2/2/4 6/3/4
f 6/3/4 5/4/4 1/1/4

# --------------------------------------------------
# LADO DIREITO
# Normal: +X
# --------------------------------------------------
f 2/1/5 3/4/5 7/3/5
f 7/3/5 6/2/5 2/1/5

# --------------------------------------------------
# LADO ESQUERDO
# Normal: -X
# --------------------------------------------------
f 1/1/6 5/2/6 8/3/6
f 8/3/6 4/4/6 1/1/6